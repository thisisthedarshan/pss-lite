{
    "name": "pss",
    "displayName": "Portable Test and Stimulus Standard",
    "description": "Syntax highlighting for Portable Test and Stimulus Standard",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.109.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "browser": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "pss.helloWorld",
                "title": "Hello World"
            }
        ],
        "grammars": [
            {
                "language": "pss",
                "scopeName": "source.pss",
                "path": "./syntaxes/pss.tmLanguage.json"
            }
        ],
        "languages": [
            {
                "id": "pss",
                "aliases": [
                    "Portable Test and Stimulus Standard"
                ],
                "extensions": [
                    ".pss"
                ],
                "configuration": "./language-configuration.json"
            }
        ]
    },
    "scripts": {
        "test": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/index.js",
        "pretest": "npm run compile-web",
        "vscode:prepublish": "npm run package-web",
        "compile-web": "webpack",
        "watch-web": "webpack --watch",
        "package-web": "webpack --mode production --devtool hidden-source-map",
        "lint": "eslint src",
        "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
    },
    "devDependencies": {
        "@types/assert": "^1.5.11",
        "@types/mocha": "^10.0.10",
        "@types/vscode": "^1.109.0",
        "@types/webpack-env": "^1.18.8",
        "@vscode/test-web": "^0.0.80",
        "assert": "^2.1.0",
        "eslint": "^9.39.3",
        "mocha": "^7.2.0",
        "process": "^0.11.10",
        "ts-loader": "^9.5.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "webpack": "^5.105.3",
        "webpack-cli": "^6.0.1"
    },
    "repository": {
        "url": "https://github.com/thisisthedarshan/pss-lite"
    }
}